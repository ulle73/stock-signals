# Copy this file to .env.local
# DATABASE_TARGET controls which connection string the app/scripts use.
# - cockroach -> DATABASE_URL_COCKROACH
# - default -> DATABASE_URL
# Example default URL: postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
# Example Cockroach URL:
# postgresql://USER:PASSWORD@HOST.cockroachlabs.cloud:26257/DBNAME?sslmode=verify-full
DATABASE_TARGET="cockroach"
DATABASE_URL=""
DATABASE_URL_COCKROACH=""

NODE_ENV="development"
ALPACA_API_BASE_URL="https://paper-api.alpaca.markets/v2"
ALPACA_API_KEY=""
ALPACA_API_SECRET=""
ALPACA_TRADING_ENABLED="false"
EXECUTION_ALLOWED_SYMBOLS="SPY"
EXECUTION_MAX_ORDER_NOTIONAL_USD="100000"
EXECUTION_MAX_POSITION_NOTIONAL_USD="100000"
EXECUTION_MAX_SIGNAL_AGE_DAYS="5"
FETCH_TICKER_LIMIT=""
YAHOO_DAILY_RANGE=""
YAHOO_INTRADAY_60M_RANGE=""
YAHOO_PROXY_DAILY_RANGE=""
YAHOO_PROXY_DAILY_INITIAL_RANGE=""
IMPLIED_VOLATILITY_PROXY_RANGE=""
