# Copy this file to .env.local
# DATABASE_TARGET controls which connection string the app/scripts use.
# - default -> DATABASE_URL
# - cockroach -> DATABASE_URL_COCKROACH
# Example Neon URL: postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require
# Example Cockroach URL: postgresql://USER:PASSWORD@HOST.cockroachlabs.cloud:26257/DBNAME?sslmode=verify-full
DATABASE_TARGET="default"
DATABASE_URL=""
DATABASE_URL_COCKROACH=""

NODE_ENV="development"
ALPACA_API_BASE_URL="https://paper-api.alpaca.markets/v2"
ALPACA_API_KEY=""
ALPACA_API_SECRET=""
ALPACA_TRADING_ENABLED="false"
EXECUTION_ALLOWED_SYMBOLS="SPY"
EXECUTION_MAX_ORDER_NOTIONAL_USD="100000"
EXECUTION_MAX_POSITION_NOTIONAL_USD="100000"
EXECUTION_MAX_SIGNAL_AGE_DAYS="5"
ENABLE_SIGNAL_STUDY_LAB="false"
SIGNAL_STUDY_ACCESS_TOKEN=""

# Optional multi-account Markov paper trading setup
MARKOV_PAPER_ACCOUNTS=""
MARKOV_PAPER_BEAR10_STRATEGY_NAME="bottom_10_bear_weekly"
MARKOV_PAPER_BEAR10_API_BASE_URL="https://paper-api.alpaca.markets/v2"
MARKOV_PAPER_BEAR10_API_KEY=""
MARKOV_PAPER_BEAR10_API_SECRET=""
MARKOV_PAPER_BEAR10_TRADING_ENABLED="false"
MARKOV_PAPER_BEAR10_SHORTING_ENABLED="true"
MARKOV_PAPER_BULL10_STRATEGY_NAME="top_10_bull_weekly"
MARKOV_PAPER_BULL10_API_BASE_URL="https://paper-api.alpaca.markets/v2"
MARKOV_PAPER_BULL10_API_KEY=""
MARKOV_PAPER_BULL10_API_SECRET=""
MARKOV_PAPER_BULL10_TRADING_ENABLED="false"
MARKOV_PAPER_BULL20_STRATEGY_NAME="top_20_bull_weekly"
MARKOV_PAPER_BULL20_API_BASE_URL="https://paper-api.alpaca.markets/v2"
MARKOV_PAPER_BULL20_API_KEY=""
MARKOV_PAPER_BULL20_API_SECRET=""
MARKOV_PAPER_BULL20_TRADING_ENABLED="false"
FETCH_TICKER_LIMIT=""
YAHOO_DAILY_RANGE=""
YAHOO_INTRADAY_60M_RANGE=""
YAHOO_PROXY_DAILY_RANGE=""
YAHOO_PROXY_DAILY_INITIAL_RANGE="400d"
IMPLIED_VOLATILITY_PROXY_RANGE="400d"
HISTORY_PRUNE_ENABLED="false"
HISTORY_PRUNE_DAILY_DAYS="400"
HISTORY_PRUNE_INTRADAY_60M_DAYS="60"
HISTORY_PRUNE_MACRO_PROXY_DAYS="400"
